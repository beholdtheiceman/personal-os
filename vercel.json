{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/notifications/daily",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/notifications/habits",
      "schedule": "0 13 * * *"
    }
  ]
}
