# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Firebase Client (public — safe to expose) ─────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-only — keep secret) ────────────────────────────
# Find in Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines, wrapped in double quotes:
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Google OAuth (Calendar + Health) ─────────────────────────────────────────
# Find in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── OpenAI (voice transcription — optional) ───────────────────────────────────
OPENAI_API_KEY=

# ── Second Brain (local only — leave blank on Vercel) ────────────────────────
# Defaults to C:\Users\Larry\Documents\SecondBrain if not set
# SECOND_BRAIN_PATH=
